#. Plugin Name of the plugin
#: catalog.php
msgid "Catalog - Catalog Mode for WooCommerce"
msgstr "Catalog - Tryb katalogu dla WooCommerce"

#. Plugin URI of the plugin
#: catalog.php
msgid "https://plogins.com/catalog/"
msgstr "https://plogins.com/catalog/"

#. Description of the plugin
#: catalog.php
msgid "Turn your store into a catalog: hide prices and/or add-to-cart, store-wide or by product, category or role."
msgstr "Zamień swój sklep w katalog: ukryj ceny i/lub przycisk dodawania do koszyka — w całym sklepie albo dla wybranego produktu, kategorii lub roli."

#. Author of the plugin
#: catalog.php
msgid "WPPoland"
msgstr "WPPoland"

#. Author URI of the plugin
#: catalog.php
msgid "https://plogins.com/"
msgstr "https://plogins.com/"

#: catalog.php:47
msgid "Catalog - Catalog Mode for WooCommerce requires WooCommerce to be active."
msgstr "Catalog - Tryb katalogu dla WooCommerce wymaga aktywnej wtyczki WooCommerce."

#: src/Admin/Settings.php:50
msgid "Settings"
msgstr "Ustawienia"

#: src/Admin/Settings.php:76
msgid "Catalog Mode"
msgstr "Tryb katalogu"

#: src/Admin/Settings.php:77
msgid "Catalog"
msgstr "Katalog"

#: src/Admin/Settings.php:116
msgid "Turn your store into a catalog"
msgstr "Zamień swój sklep w katalog"

#: src/Admin/Settings.php:118
msgid "Hide prices and/or the add-to-cart button across your store, or only for certain visitors (for example, show prices to logged-in wholesale customers)."
msgstr "Ukryj ceny i/lub przycisk dodawania do koszyka w całym sklepie albo tylko dla wybranych odwiedzających (na przykład pokazuj ceny zalogowanym klientom hurtowym)."

#: src/Admin/Settings.php:127
msgid "What to hide"
msgstr "Co ukryć"

#: src/Admin/Settings.php:131
msgid "Enable catalog mode"
msgstr "Włącz tryb katalogu"

#: src/Admin/Settings.php:135
msgid "Apply catalog mode on the storefront."
msgstr "Stosuj tryb katalogu w sklepie."

#: src/Admin/Settings.php:137
msgid "The master switch. When off, nothing is hidden and the catalog stylesheet is not loaded."
msgstr "Przełącznik główny. Po wyłączeniu nic nie jest ukrywane, a arkusz stylów katalogu nie jest ładowany."

#: src/Admin/Settings.php:141
msgid "Hide the price"
msgstr "Ukryj cenę"

#: src/Admin/Settings.php:141
msgid "Remove the price from catalog products."
msgstr "Usuń cenę z produktów w trybie katalogu."

#: src/Admin/Settings.php:141
msgid "Removes the price wherever WooCommerce would print it. Optionally show a notice such as \"Contact us for pricing\" below."
msgstr "Usuwa cenę wszędzie tam, gdzie wyświetlałby ją WooCommerce. Opcjonalnie wyświetl poniżej komunikat, np. „Skontaktuj się z nami w sprawie ceny”."

#: src/Admin/Settings.php:142
msgid "Hide add-to-cart"
msgstr "Ukryj dodawanie do koszyka"

#: src/Admin/Settings.php:142
msgid "Remove the add-to-cart button and block purchasing."
msgstr "Usuń przycisk dodawania do koszyka i zablokuj zakupy."

#: src/Admin/Settings.php:142
msgid "Removes the add-to-cart button on product pages and listings, and prevents catalog products from being purchased server-side."
msgstr "Usuwa przycisk dodawania do koszyka na stronach produktów i listach oraz uniemożliwia zakup produktów w trybie katalogu po stronie serwera."

#: src/Admin/Settings.php:146
msgid "Price notice"
msgstr "Komunikat o cenie"

#: src/Admin/Settings.php:149
msgid "e.g. Contact us for pricing"
msgstr "np. Skontaktuj się z nami w sprawie ceny"

#: src/Admin/Settings.php:150
msgid "Optional text shown where the price would be. Leave blank to show nothing."
msgstr "Opcjonalny tekst wyświetlany w miejscu ceny. Pozostaw puste, aby nic nie wyświetlać."

#: src/Admin/Settings.php:158
msgid "Who it applies to"
msgstr "Kogo dotyczy"

#: src/Admin/Settings.php:163
msgid "Visitor rule"
msgstr "Reguła odwiedzających"

#: src/Admin/Settings.php:170
msgid "Everyone"
msgstr "Wszyscy"

#: src/Admin/Settings.php:171
msgid "Only logged-out visitors"
msgstr "Tylko niezalogowani odwiedzający"

#: src/Admin/Settings.php:172
msgid "Only selected roles"
msgstr "Tylko wybrane role"

#: src/Admin/Settings.php:173
msgid "Everyone except selected roles"
msgstr "Wszyscy z wyjątkiem wybranych ról"

#: src/Admin/Settings.php:182
msgid "Restrict catalog mode by who is viewing. For a wholesale store, choose \"Everyone except selected roles\" and tick your wholesale role so those customers still see prices and can buy."
msgstr "Ogranicz tryb katalogu w zależności od tego, kto przegląda sklep. W przypadku sklepu hurtowego wybierz „Wszyscy z wyjątkiem wybranych ról” i zaznacz swoją rolę hurtową, aby ci klienci nadal widzieli ceny i mogli kupować."

#: src/Admin/Settings.php:186
#: src/Admin/Settings.php:189
msgid "Roles"
msgstr "Role"

#: src/Admin/Settings.php:199
msgid "Used by the two \"selected roles\" options above. Tick the roles the rule applies to."
msgstr "Używane przez dwie powyższe opcje „wybrane role”. Zaznacz role, których dotyczy reguła."
